{
    "$schema": "https://raw.githubusercontent.com/Outer-Wilds-New-Horizons/new-horizons/main/NewHorizons/Schemas/body_schema.json",
    "name": "Attlerock",
    "starSystem": "SolarSystem",

    "Base": {
        "comment": "为废岩星(世末之城)增加重力,让玩家稳稳站在地面。surfaceSize 应覆盖道具分布(半径≈30~76),surfaceGravity 参考 Timber Hearth=12。这些值会覆盖原版废岩星,需进游戏微调站立手感。",
        "surfaceGravity": 10.0,
        "surfaceSize": 80.0,
        "gravityFallOff": "linear"
    },

    "Atmosphere": {
        "comment": "大气层(雨/雾的边界)。size=大气层标高;useAtmosphereShader 给出可见的大气壳。体积雾与体积雨由 C# 限制在 AttlerockAtmosphereRadius(≈150)内。",
        "hasOxygen": true,
        "size": 130,
        "atmosphereTint": {"r": 140, "g": 158, "b": 184, "a": 255},
        "useAtmosphereShader": true,
        "clouds": {
            "comment": "云层(复用原版巨深星 GiantsDeep 云资产,染成灰蓝阴云,契合末日暴雨)。云壳半径在地表(surfaceSize 80)之上、大气层(size 130)之内,高于高塔(半径≈76);tint 用 0-255 整数。",
            "cloudsPrefab": "giantsDeep",
            "innerCloudRadius": 85,
            "outerCloudRadius": 105,
            "tint": {"r": 120, "g": 134, "b": 150, "a": 255},
            "rotationSpeed": 2.0
        }
    },

    "comment": "废岩星(Attlerock)·世末之城。地表起伏不平且有陨石坑，道具半径统一抬到 ≈56 以避免陷入地表；歌者在北极平台、天依在南极平台。实际 y 仍需进游戏用 Debug Raycast(P 键)按地形微调。",

