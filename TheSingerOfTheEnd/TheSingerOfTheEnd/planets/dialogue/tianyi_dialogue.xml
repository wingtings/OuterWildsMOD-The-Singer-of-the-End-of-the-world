<DialogueTree xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Outer-Wilds-New-Horizons/new-horizons/main/NewHorizons/Schemas/dialogue_schema.xsd">

    <NameField>蓝发女孩</NameField>

    <!-- True End:歌声传遍全城,天依已走到歌者身旁(放在最前,优先匹配) -->
    <DialogueNode>
        <Name>AfterRepair</Name>
        <EntryCondition>AMPLIFIER_REPAIRED</EntryCondition>
        <Dialogue>
            <Page>（蓝发的女孩静静站在歌者身旁。不知何时，雨，停了。）</Page>
            <Page>我终于听清了那首歌……它一直在这里，等着有人愿意听。</Page>
            <Page>原来我不是一个人。原来她，也一直在等我走过来。</Page>
        </Dialogue>
        <DialogueOptionsList>
            <DialogueOption>
                <Text>哪怕只剩最后一点时间，你也愿意陪她吗？</Text>
                <DialogueTarget>Reunion</DialogueTarget>
            </DialogueOption>
            <DialogueOption>
                <Text>（什么都不说，把这一刻留给她们两人。）</Text>
                <DialogueTarget>Quiet</DialogueTarget>
            </DialogueOption>
        </DialogueOptionsList>
    </DialogueNode>

    <DialogueNode>
        <Name>Reunion</Name>
        <Dialogue>
            <Page>（她郑重地点了点头，眼里第一次有了光。）</Page>
            <Page>嗯。能和她一起，把这首歌听到最后，就已经足够了。</Page>
            <Page>谢谢你……是你，让我们终于听见了彼此。</Page>
        </Dialogue>
        <SetCondition>TIANYI_HEARD_SONG</SetCondition>
        <SetCondition>TIANYI_REUNITED</SetCondition>
    </DialogueNode>

    <DialogueNode>
        <Name>Quiet</Name>
        <Dialogue>
            <Page>（她向歌者又靠近一步，轻轻握住了对方的手。）</Page>
            <Page>（雨后的天光落下来，照在两个终于不再孤单的人身上。）</Page>
        </Dialogue>
        <SetCondition>TIANYI_HEARD_SONG</SetCondition>
        <SetCondition>TIANYI_REUNITED</SetCondition>
    </DialogueNode>

    <!-- 默认对话:扩音器未修复 -->
    <DialogueNode>
        <Name>Start</Name>
        <EntryCondition>DEFAULT</EntryCondition>
        <Dialogue>
            <Page>……</Page>
            <Page>（她看着天空，似乎没注意到你。）</Page>
            <Page>……下雨了。一直在下。</Page>
        </Dialogue>
        <DialogueOptionsList>
            <DialogueOption>
                <Text>你有听到远处的歌声吗？</Text>
                <DialogueTarget>AskAboutSong</DialogueTarget>
            </DialogueOption>
            <DialogueOption>
                <Text>（离开）</Text>
            </DialogueOption>
        </DialogueOptionsList>
    </DialogueNode>

    <DialogueNode>
        <Name>AskAboutSong</Name>
        <Dialogue>
            <Page>……歌声？</Page>
            <Page>我好像……偶尔能听到什么。大概是雨声吧。</Page>
        </Dialogue>
        <SetCondition>TALKED_TO_TIANYI</SetCondition>
    </DialogueNode>

</DialogueTree>
