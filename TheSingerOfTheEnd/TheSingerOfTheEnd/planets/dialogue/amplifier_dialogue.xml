<DialogueTree xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Outer-Wilds-New-Horizons/new-horizons/main/NewHorizons/Schemas/dialogue_schema.xsd">

    <NameField>损坏的扩音装置</NameField>

    <!-- 已修复:再次查看只做提示 -->
    <DialogueNode>
        <Name>AlreadyFixed</Name>
        <EntryCondition>AMPLIFIER_REPAIRED</EntryCondition>
        <Dialogue>
            <Page>扩音装置正在运转。歌声回荡在整座城市的雨幕里。</Page>
        </Dialogue>
    </DialogueNode>

    <!-- 默认:损坏状态。修复改由"把零件插进装置上的两个插槽"完成(交互式),此处仅作说明。 -->
    <DialogueNode>
        <Name>Start</Name>
        <EntryCondition>DEFAULT</EntryCondition>
        <Dialogue>
            <Page>舞台后方的扩音装置已经损坏，正面露出两个空着的插槽。</Page>
            <Page>一处插槽的形状像是高塔里那枚精密零件；另一处，则像是能嵌入一枚共鸣核心。</Page>
            <Page>把两枚零件分别嵌进插槽，也许就能让它重新运转。</Page>
        </Dialogue>
    </DialogueNode>

</DialogueTree>
